# Microsoft Azure AD (MSAL) – Outlook Kalender & To Do für weller@pht.group
# App-Registrierung: https://portal.azure.com → App registrations → SPA
# Redirect URI: http://localhost:5173 und https://pht-mastertool.vercel.app
# API Permissions: Calendars.ReadWrite, Tasks.ReadWrite, User.Read (delegated)
VITE_AZURE_CLIENT_ID=your-azure-app-client-id
VITE_AZURE_TENANT_ID=your-pht-tenant-id-or-common
VITE_MS_DEFAULT_USER=weller@pht.group

# SOPHIE KI-Assistentin (OpenAI – nur Server/Vercel, NICHT VITE_ prefix!)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Vergabeportale – nur Server/Vercel (NICHT VITE_ prefix!)
# Doffin Norwegen: https://dof-notices-prod-api.developer.azure-api.net/
DOFFIN_API_KEY=your-doffin-subscription-key
# HILMA Finnland: https://hns-hilma-prod-apim.developer.azure-api.net/ → avp-read
HILMA_API_KEY=your-hilma-subscription-key
