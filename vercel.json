{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/ted", "destination": "/api/ted" },
    { "source": "/api/assistant", "destination": "/api/assistant" },
    { "source": "/api/uk", "destination": "/api/uk" },
    { "source": "/api/uk-contracts", "destination": "/api/uk?target=contracts" },
    { "source": "/api/uk-find-tender", "destination": "/api/uk?target=find-tender" },
    { "source": "/api/uk-cf-ocds", "destination": "/api/uk?target=cf-ocds" },
    { "source": "/api/doffin", "destination": "/api/tenders/doffin" },
    { "source": "/api/hilma", "destination": "/api/tenders/hilma" },
    { "source": "/api/austender/:path*", "destination": "/api/tenders/austender/:path*" },
    { "source": "/api/austender", "destination": "/api/tenders/austender" },
    { "source": "/api/bund", "destination": "/api/tenders/bund" },
    { "source": "/api/tenderned", "destination": "/api/tenders/tenderned" },
    { "source": "/api/bbg", "destination": "/api/tenders/bbg" },
    { "source": "/api/simap", "destination": "/api/tenders/simap" },
    { "source": "/api/prozorro/:path*", "destination": "/api/tenders/prozorro/:path*" },
    { "source": "/api/prozorro", "destination": "/api/tenders/prozorro" },
    { "source": "/api/za-etenders", "destination": "/api/tenders/za-etenders" },
    { "source": "/api/tenders/oeffentlichevergabe", "destination": "/api/tenders/oeffentlichevergabe" },
    { "source": "/api/tenders/:path*", "destination": "/api/tenders/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
