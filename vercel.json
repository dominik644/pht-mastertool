{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/ted", "destination": "/api/ted" },
    { "source": "/api/assistant", "destination": "/api/assistant" },
    { "source": "/api/uk", "destination": "/api/uk" },
    { "source": "/api/oeffentlichevergabe", "destination": "/api/oeffentlichevergabe" },
    { "source": "/api/uk-contracts", "destination": "/api/uk?target=contracts" },
    { "source": "/api/uk-find-tender", "destination": "/api/uk?target=find-tender" },
    { "source": "/api/uk-cf-ocds", "destination": "/api/uk?target=cf-ocds" },
    { "source": "/api/doffin", "destination": "/api/tenders?source=doffin" },
    { "source": "/api/hilma", "destination": "/api/tenders?source=hilma" },
    { "source": "/api/austender/:rest*", "destination": "/api/tenders?source=austender&rest=:rest*" },
    { "source": "/api/austender", "destination": "/api/tenders?source=austender" },
    { "source": "/api/bund", "destination": "/api/tenders?source=bund" },
    { "source": "/api/tenderned", "destination": "/api/tenders?source=tenderned" },
    { "source": "/api/bbg", "destination": "/api/tenders?source=bbg" },
    { "source": "/api/simap", "destination": "/api/tenders?source=simap" },
    { "source": "/api/prozorro/:rest*", "destination": "/api/tenders?source=prozorro&rest=:rest*" },
    { "source": "/api/prozorro", "destination": "/api/tenders?source=prozorro" },
    { "source": "/api/za-etenders", "destination": "/api/tenders?source=za-etenders" },
    { "source": "/api/tenders/oeffentlichevergabe", "destination": "/api/oeffentlichevergabe" },
    { "source": "/api/tenders/austender/:rest*", "destination": "/api/tenders?source=austender&rest=:rest*" },
    { "source": "/api/tenders/mtender/:rest*", "destination": "/api/tenders?source=mtender&rest=:rest*" },
    { "source": "/api/tenders/prozorro/:rest*", "destination": "/api/tenders?source=prozorro&rest=:rest*" },
    { "source": "/api/tenders/:source", "destination": "/api/tenders?source=:source" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
